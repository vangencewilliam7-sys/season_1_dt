# =============================================================================
# Digital Twin — Root .gitignore
# Covers the entire monorepo (backend, frontend, legacy projects)
# =============================================================================


# ── Secrets — NEVER commit these ─────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
*.env

# Exception: allow .env.example files (they contain no real secrets)
!.env.example
!**/.env.example
!**/.env.local.example


# ── Python (backend/) ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# MyPy / type checking
.mypy_cache/
.dmypy.json

# Pytest
.pytest_cache/
.coverage
htmlcov/


# ── Node / Next.js (frontend/) ────────────────────────────────────────────────
node_modules/
.next/
out/
.cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*


# ── Uploads — may contain sensitive expert documents ─────────────────────────
**/uploads/
**/data/expert_docs/


# ── OS generated ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini


# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace


# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log


# ── LangGraph / LangSmith ────────────────────────────────────────────────────
.langgraph/


# ── Prisma ────────────────────────────────────────────────────────────────────
# (schema.prisma IS committed — only generated artifacts are ignored)
prisma/migrations/**/migration_lock.toml


# ── Misc ──────────────────────────────────────────────────────────────────────
*.tmp
*.bak
*.orig
implementation_plan.md
