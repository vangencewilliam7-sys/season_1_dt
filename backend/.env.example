# =============================================================================
# Digital Twin — Backend Environment Template
# Copy this to .env and fill in your credentials.
# =============================================================================


# ── LLM Provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=openai                             # "openai" | "groq" | "mock"

OPENAI_API_KEY=sk-...                           # Your OpenAI API key
OPENAI_INGESTION_MODEL=gpt-4o
OPENAI_JOURNALIST_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Groq (optional fallback)
GROQ_API_KEY=gsk_...
GROQ_INGESTION_MODEL=llama-3.1-70b-versatile
GROQ_JOURNALIST_MODEL=llama-3.1-8b-instant


# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...               # From Supabase → Settings → API
SUPABASE_ANON_KEY=eyJ...                       # From Supabase → Settings → API

SUPABASE_CHUNKS_TABLE=document_chunks
SUPABASE_MASTER_CASES_TABLE=master_cases
SUPABASE_MANIFESTS_TABLE=persona_manifests
SUPABASE_PIPELINE_STATE_TABLE=pipeline_state


# ── Expert Persona Framework ───────────────────────────────────────────────────
DOMAIN_ADAPTER=healthcare
READER_TYPE=supabase
FILESYSTEM_READER_BASE_DIR=data/expert_docs


# ── LangSmith (optional) ──────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=digital-twin-season-1


# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO


# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
